# =============================================================================
# SatuRun (PACE) — Local Development Environment
# =============================================================================
# Copy this file to .env and fill in the values for your local setup.
#   cp .env.example .env    (bash)
#   copy .env.example .env  (PowerShell)
# =============================================================================

# --- Database (required by lib/db, api-server) ---
# PostgreSQL connection string
# Local: postgresql://postgres:password@localhost:5432/saturun
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/saturun

# --- API Server (required by artifacts/api-server) ---
PORT=5000

# --- Mockup Sandbox (required by artifacts/mockup-sandbox) ---
MOCKUP_SANDBOX_PORT=3001
BASE_PATH=/

# --- Mobile App (optional overrides) ---
# EXPO_PUBLIC_DOMAIN=http://localhost:5000

# --- Strava Integration (required for Strava OAuth) ---
# Create your app at https://www.strava.com/settings/api
# Set redirect URI to: saturun://strava-callback
EXPO_PUBLIC_STRAVA_CLIENT_ID=
EXPO_PUBLIC_STRAVA_CLIENT_SECRET=
